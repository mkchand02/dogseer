{
  "manifest_version": 3,
  "name": "DOGSeer",
  "version": "0.1.0",
  "description": "AI-powered accessibility assistant for Gmail and WhatsApp Web",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabCapture",
    "tts",
    "tabs",
    "offscreen"
  ],

  "host_permissions": [
    "https://mail.google.com/*",
    "https://web.whatsapp.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content_scripts/gmail.js"],
      "css": ["content_scripts/statusbar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content_scripts/whatsapp.js"],
      "css": ["content_scripts/statusbar.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "DOGSeer"
  }
}
